# ============================================================
# WILLPOWER MERCH PLATFORM — PORTAL ENVIRONMENT VARIABLES
# Copy to `.env.local` and fill in real values. Never commit .env.local.
# ============================================================

# ----- SUPABASE -----
# Create a project at https://supabase.com.
# Settings → API → copy these.
NEXT_PUBLIC_SUPABASE_URL=<paste your project URL e.g. https://xxxx.supabase.co>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste the anon/public key>
# Service role key — server-only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=<paste the service_role secret>

# ----- STRIPE -----
# Dashboard → Developers → API keys. Use TEST keys until you have placed
# end-to-end test orders and verified everything works.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<paste pk_test_... here>
STRIPE_SECRET_KEY=<paste sk_test_... here>
STRIPE_WEBHOOK_SECRET=<paste whsec_... after you create the webhook>

# Subscription price IDs (Stripe Dashboard → Products → create a recurring
# product for each plan, then copy the price ID — starts with `price_...`).
STRIPE_PRICE_PRO=<price_... for $29/mo Pro plan>
STRIPE_PRICE_ELITE=<price_... for $79/mo Elite plan>
# Free plan has no Stripe price — it skips the subscription step.

# Stripe Connect client ID — Dashboard → Connect → Settings → "Connect onboarding".
# Required to let clients link their Stripe account from Settings.
STRIPE_CONNECT_CLIENT_ID=<paste ca_... value>

# ----- PRINTIFY -----
# Generate an API token at https://printify.com/app/account/api.
# All client products live under this single WPFF-owned shop.
PRINTIFY_API_KEY=<paste your Printify API token>
PRINTIFY_SHOP_ID=<paste the WPFF shop ID>

# ----- CLOUDINARY -----
# Sign up at https://cloudinary.com. Dashboard → top-right → copy the
# whole CLOUDINARY_URL (format: cloudinary://<key>:<secret>@<cloud_name>).
CLOUDINARY_URL=<paste cloudinary://api_key:api_secret@cloud_name>
# Public cloud name for client-side uploads (just the cloud_name part).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<paste the cloud_name>
# Upload preset configured as "unsigned" in Cloudinary → Settings → Upload.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=<preset name e.g. wpff_portal>

# ----- RESEND -----
RESEND_API_KEY=<paste re_... here>
RESEND_FROM_EMAIL=hello@willpowerfitnessfactory.com

# ----- SITE -----
# Public URL of the portal (no trailing slash). Used for OAuth callbacks,
# Stripe redirects, email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
