# ============================================================
# WILL POWER FITNESS FACTORY — ENV VARS
# Set these in Vercel → Project Settings → Environment Variables.
# `.env.local` is gitignored locally for development.
# ============================================================

# ----- STRIPE -----
# Dashboard → Developers → API keys. Use TEST keys until you've
# placed end-to-end test orders.
STRIPE_PUBLISHABLE_KEY=<paste pk_test_... from Stripe>
STRIPE_SECRET_KEY=<paste sk_test_... from Stripe>

# Webhook signing secret. Created when you add the endpoint at
# Stripe Dashboard → Developers → Webhooks → "Add endpoint".
# Endpoint URL once deployed: https://YOUR-DOMAIN/api/webhooks/stripe
# Event to listen for: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=<paste whsec_... from the webhook detail page>

# ----- PRINTIFY -----
# Generate a token at https://printify.com/app/account/api
# Find the shop ID via `curl -H "Authorization: Bearer <token>" https://api.printify.com/v1/shops.json`
PRINTIFY_API_KEY=<paste your Printify API token>
PRINTIFY_SHOP_ID=<paste the numeric shop ID>

# Per-product Printify IDs. Create each product in Printify (upload
# the design, pick variants, save), then paste its product_id here.
# Items with no ID configured are skipped during fulfillment — the
# customer is still charged and you can ship manually.
PRINTIFY_PRODUCT_ID_TEE=
PRINTIFY_PRODUCT_ID_TANK=
PRINTIFY_PRODUCT_ID_HOODIE=
PRINTIFY_PRODUCT_ID_SNAPBACK=

# ----- RESEND (optional, for email confirmation) -----
# If left blank, the order succeeds and Printify still fulfills,
# but no transactional email is sent to the customer.
RESEND_API_KEY=

# ----- PORTAL SYNC (optional, mirrors orders to GoElev8 portal) -----
# When set, every successful order is also POSTed to the GoElev8
# portal's /api/external/orders endpoint so it shows up in the WPFF
# tenant dashboard at portal.goelev8.ai/portal/dashboard/orders.
# Sync failures do NOT affect the customer — they're best-effort.
#
# Setup (one time, after both this site AND the portal are deployed):
#   1. In the portal's Supabase SQL editor, apply migration
#      002_external_storefronts.sql.
#   2. Find the WPFF client_id in clients table (or create one if WPFF
#      hasn't signed up yet — see portal README "manual onboarding").
#   3. Run: select public.rotate_client_api_key('WPFF-client-uuid');
#   4. Copy the returned `external_xxx` key into PORTAL_API_KEY below.
PORTAL_SYNC_URL=https://portal.goelev8.ai
PORTAL_API_KEY=
