# ============================================================
# WILL POWER FITNESS FACTORY — SHOP ENVIRONMENT VARIABLES
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it's in .gitignore.
# ============================================================

# ----- STRIPE (payments) -----
# Get these from https://dashboard.stripe.com/test/apikeys
# Start with TEST keys (pk_test_... / sk_test_...). Switch to live keys
# only after you've placed test orders end-to-end successfully.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<paste pk_test_... from Stripe dashboard>
STRIPE_SECRET_KEY=<paste sk_test_... from Stripe dashboard>

# Stripe webhook signing secret. Created when you add a webhook endpoint
# in Stripe Dashboard → Developers → Webhooks → "Add endpoint".
# Endpoint URL once deployed: https://YOUR-DOMAIN/api/webhooks/stripe
# Events to listen for: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=<paste whsec_... after creating the webhook in Step 7>

# ----- PRINTIFY (print-on-demand) -----
# Generate at https://printify.com/app/account/api
PRINTIFY_API_KEY=<paste your Printify API token here>
# Find your shop ID at https://api.printify.com/v1/shops.json (use the API key
# above with an Authorization: Bearer header). Pick the shop that matches the
# storefront you want orders sent to.
PRINTIFY_SHOP_ID=12345678

# Per-product Printify IDs. Create each product in Printify first, then paste
# its product_id here. Until set, the shop shows the product with a kettlebell
# placeholder image and "Coming soon" state.
PRINTIFY_PRODUCT_TEE=
PRINTIFY_PRODUCT_HOODIE=
PRINTIFY_PRODUCT_SNAPBACK=
PRINTIFY_PRODUCT_JOGGERS=
PRINTIFY_PRODUCT_TANK=
PRINTIFY_PRODUCT_TUMBLER=

# ----- RESEND (transactional email) -----
# Sign up at https://resend.com → create an API key.
# Verify a sending domain (or use Resend's onboarding sandbox).
RESEND_API_KEY=<paste re_... from Resend dashboard>
# Email address customer order confirmations come FROM. Must be on a domain
# you've verified in Resend (e.g. orders@willpowerfitnessfactory.com).
RESEND_FROM_EMAIL=orders@willpowerfitnessfactory.com

# ----- ADMIN PANEL -----
# Single password gating /admin. Pick something long and random. Change it
# whenever you want to revoke access.
ADMIN_PASSWORD=change-me-to-something-random

# ----- SITE -----
# Public URL the store is served at (no trailing slash). Used in email links
# and Stripe redirects. e.g. https://shop.willpowerfitnessfactory.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
